# Database — uses host.docker.internal (mapped via extra_hosts in docker-compose.yml)
# to reach postgresql15 on the Unraid host. Postgres currently binds 0.0.0.0:5432.
DATABASE_URL=postgres://ebertx:CHANGEME@host.docker.internal:5432/jeopardy

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=CHANGEME

# OpenAI API key — required for /study recommendations
OPENAI_API_KEY=sk-CHANGEME

# Optional: bind address inside the container (default 0.0.0.0:3000)
# HOST=0.0.0.0
# PORT=3000
