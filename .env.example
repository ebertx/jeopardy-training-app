# Database — reach PostgreSQL on Tower via the docker bridge gateway.
# (postgresql15 currently binds 0.0.0.0:5432; the host gateway works from any bridged container.)
DATABASE_URL=postgres://ebertx:CHANGEME@172.17.0.1:5432/jeopardy

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=CHANGEME

# OpenAI API key — required for /study recommendations
OPENAI_API_KEY=sk-CHANGEME

# Optional: bind address inside the container (default 0.0.0.0:3000)
# HOST=0.0.0.0
# PORT=3000
